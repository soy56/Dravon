<?xml version="1.0" ?>
<robot name="bipedal_dummy">
  <!-- This is a placeholder bipedal robot so the simulation has a physical body with legs to process -->
  
  <link name="world"/>
  
  <joint name="fixed_base" type="fixed">
    <parent link="world"/>
    <child link="torso"/>
    <origin xyz="0 0 1.0"/>
  </joint>

  <!-- Torso -->
  <link name="torso">
    <inertial>
      <mass value="15.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.5"/>
    </inertial>
    <visual>
      <geometry><box size="0.3 0.2 0.5"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
  </link>

  <!-- Right Arm -->
  <link name="right_upper_arm">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 -0.15"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.15"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
    </visual>
  </link>
  <joint name="right_shoulder_joint" type="revolute">
    <parent link="torso"/>
    <child link="right_upper_arm"/>
    <origin xyz="0.2 0 0.2"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="50" velocity="5"/>
  </joint>

  <!-- Left Arm -->
  <link name="left_upper_arm">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 -0.15"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.15"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
    </visual>
  </link>
  <joint name="left_shoulder_joint" type="revolute">
    <parent link="torso"/>
    <child link="left_upper_arm"/>
    <origin xyz="-0.2 0 0.2"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="50" velocity="5"/>
  </joint>

  <!-- Right Leg -->
  <link name="right_thigh">
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 -0.2"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.2"/>
      <geometry><cylinder radius="0.06" length="0.4"/></geometry>
    </visual>
  </link>
  <joint name="right_hip_joint" type="revolute">
    <parent link="torso"/>
    <child link="right_thigh"/>
    <origin xyz="0.1 0 -0.25"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.0" upper="1.0" effort="100" velocity="5"/>
  </joint>

  <!-- Left Leg -->
  <link name="left_thigh">
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 -0.2"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.2"/>
      <geometry><cylinder radius="0.06" length="0.4"/></geometry>
    </visual>
  </link>
  <joint name="left_hip_joint" type="revolute">
    <parent link="torso"/>
    <child link="left_thigh"/>
    <origin xyz="-0.1 0 -0.25"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.0" upper="1.0" effort="100" velocity="5"/>
  </joint>
</robot>
